            <sample loNote="55" hiNote="55" path="Samples/splash1_OH_F_2.wav" />
            <sample loNote="55" hiNote="55" path="Samples/splash1_OH_F_3.wav" />
        </group>
        <group name="Cowbell">
            <sample loNote="56" hiNote="56" path="Samples/cowbell_FF_1.wav" />
            <sample loNote="56" hiNote="56" path="Samples/cowbell_FF_2.wav" />
            <sample loNote="56" hiNote="56" path="Samples/cowbell_FF_3.wav" />
